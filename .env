RATE_LIMIT_DELAY=1.0
REQUEST_TIMEOUT=10
MAX_RETRIES=3
LOG_LEVEL=INFO
PORT=8000

# Optional: used by GET /search (skill-based search without providing companies)
# Comma-separated lists of board tokens / site names
GREENHOUSE_COMPANIES=airbnb
LEVER_COMPANIES=canva

# Safety cap to prevent accidentally scraping too many companies in /search
SEARCH_MAX_COMPANIES=50
